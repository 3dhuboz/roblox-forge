        "$path": "src/server/RaceManager.server.luau"
      },
      "VehicleManager": {
        "$path": "src/server/VehicleManager.server.luau"
      },
      "DataManager": {
        "$path": "src/server/DataManager.server.luau"
      },
      "PlatformBehaviors": {
        "$path": "src/server/PlatformBehaviors.server.luau"
      }
